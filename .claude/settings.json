{
	"$schema": "https://json.schemastore.org/claude-code-settings.json",
	"cleanupPeriodDays": 365,
	"env": {
		"DISABLE_TELEMETRY": "1",
		"DISABLE_ERROR_REPORTING": "1",
		"CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
		"CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
	},
	"enableAllProjectMcpServers": false,
	"alwaysThinkingEnabled": true,
	"hooks": {
		"PreToolUse": [
			{
				"matcher": "Bash",
				"hooks": [
					{ "type": "command", "command": ".claude/hooks/check-rm.sh" },
					{ "type": "command", "command": ".claude/hooks/check-git-push.sh" },
					{ "type": "command", "command": ".claude/hooks/check-gh.sh" },
					{ "type": "command", "command": ".claude/hooks/check-publish.sh" },
					{ "type": "command", "command": ".claude/hooks/check-docker-push.sh" }
				]
			}
		]
	},
	"enabledMcpsonServers": [
		"context7"
	],
	"sandbox": {
		"enabled": true,
		"autoAllowBashIfSandboxed": true
	}
}