{
	"$schema": "https://json.schemastore.org/claude-code-settings.json",
	"cleanupPeriodDays": 365,
	"env": {
		"DISABLE_TELEMETRY": "1",
		"DISABLE_ERROR_REPORTING": "1",
		"CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
		"CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
	},
	"enableAllProjectMcpServers": false,
	"alwaysThinkingEnabled": true,
	"hooks": {
		"PreToolUse": [
			{
				"matcher": "Bash",
				"hooks": [
					{ "type": "command", "command": ".claude/hooks/check-rm.sh" },
					{ "type": "command", "command": ".claude/hooks/check-git-destructive.sh" },
					{ "type": "command", "command": ".claude/hooks/check-gh.sh" },
					{ "type": "command", "command": ".claude/hooks/check-publish.sh" },
					{ "type": "command", "command": ".claude/hooks/check-docker.sh" },
					{ "type": "command", "command": ".claude/hooks/check-database.sh" },
					{ "type": "command", "command": ".claude/hooks/check-iac.sh" },
					{ "type": "command", "command": ".claude/hooks/check-network-exfil.sh" },
					{ "type": "command", "command": ".claude/hooks/check-shell-bypass.sh" },
					{ "type": "command", "command": ".claude/hooks/check-cloud-cli.sh" },
					{ "type": "command", "command": ".claude/hooks/check-deploy.sh" }
				]
			}
		]
	},
	"permissions": {
		"deny": [
			"Edit(.claude/settings.json)",
			"Write(.claude/settings.json)",
			"Edit(.claude/settings.local.json)",
			"Write(.claude/settings.local.json)",
			"Edit(.claude/hooks/**)",
			"Write(.claude/hooks/**)"
		]
	},
	"enabledMcpsonServers": [
		"context7"
	],
	"sandbox": {
		"enabled": true,
		"autoAllowBashIfSandboxed": true
	}
}