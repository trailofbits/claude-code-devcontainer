# Devcontainer environment variables
# Copy to .devc.env and fill in your values: cp .devc.env.example .devc.env
# Parsed by `devc` before building/starting the container (not shell-sourced).
# NEVER commit .devc.env — it is gitignored.

# Required — GitHub fine-grained PAT (scoped to your repos)
GH_TOKEN=

# Required — Azure OpenAI API key (for Codex CLI / /review-pr)
OPENAI_API_KEY=

# Required — Azure OpenAI endpoint URL
CODEX_AZURE_BASE_URL=

# Optional — Anthropic API key (bypasses interactive `claude login`)
ANTHROPIC_API_KEY=

# Optional — Exa AI search (used by Claude skills)
EXA_API_KEY=

# Optional — Gemini CLI (second opinion on PR reviews)
GEMINI_API_KEY=

# Optional — expose container port 8000 on this host port (omit to skip)
# DEVC_API_PORT=8000
