#!/usr/bin/env bash
# shellcheck disable=SC2139

# --- Navigation ---
alias ..="cd .."
alias ...="cd ../.."
alias ....="cd ../../.."
alias .....="cd ../../../.."

# --- Shortcuts ---
alias g="git"
alias h="history"

# --- ls (eza with fallback) ---
if command -v eza &>/dev/null; then
  alias l="eza -l --classify"
  alias la="eza -la --classify"
  alias ll="eza -la --classify"
  # Wrap eza as ls, translating common ls flags to eza equivalents
  # so that muscle-memory like `ls -lsatr` keeps working
  function ls {
    local args=()
    for arg in "$@"; do
      if [[ "$arg" =~ ^-[a-zA-Z]+$ && ! "$arg" =~ ^-- ]]; then
        local flags="${arg#-}"
        local i
        for ((i = 0; i < ${#flags}; i++)); do
          case "${flags:i:1}" in
            t) args+=(--sort=modified) ;;
            S) args+=(--sort=size) ;;
            r) args+=(--reverse) ;;
            l) args+=(-l) ;;
            a) args+=(-a) ;;
            h) args+=(-h) ;;
            s) ;;  # -s (block size) has no eza equivalent; drop silently
            F) args+=(--classify) ;;
            R) args+=(--recurse) ;;
            *) args+=("-${flags:i:1}") ;;
          esac
        done
      else
        args+=("$arg")
      fi
    done
    command eza "${args[@]}"
  }
else
  if command ls --color >/dev/null 2>&1; then
    colorflag="--color"
  else
    colorflag="-G"
  fi
  alias l="command ls -lF ${colorflag}"
  alias la="command ls -laF ${colorflag}"
  alias ll="command ls -laF ${colorflag}"
  alias ls="command ls ${colorflag}"
  export LS_COLORS='no=00:fi=00:di=01;34:ln=01;36:pi=40;33:so=01;35:do=01;35:bd=40;33;01:cd=40;33;01:or=40;31;01:ex=01;32:*.tar=01;31:*.tgz=01;31:*.arj=01;31:*.taz=01;31:*.lzh=01;31:*.zip=01;31:*.z=01;31:*.Z=01;31:*.gz=01;31:*.bz2=01;31:*.deb=01;31:*.rpm=01;31:*.jar=01;31:*.jpg=01;35:*.jpeg=01;35:*.gif=01;35:*.bmp=01;35:*.pbm=01;35:*.pgm=01;35:*.ppm=01;35:*.tga=01;35:*.xbm=01;35:*.xpm=01;35:*.tif=01;35:*.tiff=01;35:*.png=01;35:*.mov=01;35:*.mpg=01;35:*.mpeg=01;35:*.avi=01;35:*.fli=01;35:*.gl=01;35:*.dl=01;35:*.xcf=01;35:*.xwd=01;35:*.ogg=01;35:*.mp3=01;35:*.wav=01;35:'
fi

# --- cat/find replacements ---
command -v bat &>/dev/null && alias ccat='bat --paging=never'
command -v fd &>/dev/null && alias ff='fd'

# --- General ---
alias sudo='sudo '
alias week='date +%V'
alias timer='echo "Timer started. Stop with Ctrl-D." && date && time cat && date'
alias vi='vim'
alias reload="exec \$SHELL -l"

# --- Update ---
alias update='sudo apt-get update && sudo apt-get upgrade -y && sudo apt-get autoremove -y'

# --- Networking ---
alias ip="dig +short myip.opendns.com @resolver1.opendns.com"
alias whatsmyip='curl http://api.ipify.org?format=text'
alias ips="ifconfig -a | grep -o 'inet6\\? \\(addr:\\)\\?\\s\\?\\(\\(\\([0-9]\\+\\.\\)\\{3\\}[0-9]\\+\\)\\|[a-fA-F0-9:]\\+\\)' | awk '{ sub(/inet6? (addr:)? ?/, \"\"); print }'"

alias localip="hostname -I | cut -d' ' -f1"

alias netstat-proc='lsof -nP -iTCP | grep LISTEN'

# --- Clipboard ---
alias c="tr -d '\\n' | xclip -selection clipboard"

# --- File management ---
alias cleanup="find . -type f -name '*.DS_Store' -ls -delete"
command -v hd >/dev/null || alias hd="hexdump -C"
command -v md5sum >/dev/null || alias md5sum="md5"
command -v sha1sum >/dev/null || alias sha1sum="shasum"

# --- Kubernetes ---
alias ka='kubectl get pods --all-namespaces'
alias kctx='kubectl ctx'
alias kns='kubectl ns'

# --- Data processing ---
# shellcheck disable=SC2154
alias es_res_2_csv="jq '.hits.hits[]._source' | jq -s '.' | jq -r '(.[0] | keys_unsorted) as \$keys | \$keys, map([.[ \$keys[] ]])[] | @csv'"
alias date-iso='date -u +"%Y-%m-%dT%H:%M:%SZ"'
alias map="xargs -n1"
alias yat='bat --language yaml'

# --- SSH/Remote ---
alias dgx='ssh asus-gx10.lemur-lionfish.ts.net'
alias hetzner='ssh hetzner.seeqnc.com'

# --- Git ---
alias gwl="git worktree list"

# --- SSL ---
alias get-ssl-pubkey='openssl s_client -connect the.host.name:443 | openssl x509 -pubkey -noout'

# --- YAML/JSON ---
alias yaml2json="ruby -ryaml -rjson -e 'puts JSON.pretty_generate(YAML.load(ARGF))'"

# --- Claude ---
alias claude-yolo="claude --dangerously-skip-permissions"
alias copi='gh copilot suggest'
