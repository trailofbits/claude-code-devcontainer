#!/usr/bin/env bash
# shellcheck disable=SC2059,SC2086

# Simple calculator
calc() {
  local result=""
  result="$(printf "scale=10;%s\n" "$*" | bc --mathlib | tr -d '\\\n')"
  if [[ "$result" == *.* ]]; then
    printf "%s" "$result" |
      sed -e 's/^\./0./' \
          -e 's/^-\./-0./' \
          -e 's/0*$//;s/\.$//'
  else
    printf "%s" "$result"
  fi
  printf "\n"
}

# Create a new directory and enter it
mkd() {
  mkdir -p "$@" && cd "$@" || return
}

# Change working directory to the top-most Finder window location (macOS only)
if [[ "$(uname -s)" == "Darwin" ]]; then
  cdf() {
    cd "$(osascript -e 'tell app "Finder" to POSIX path of (insertion location as alias)')" || return
  }
fi

# Create a .tar.gz archive, using zopfli, pigz, or gzip for compression
targz() {
  local tmpFile="${*%/}.tar"
  tar -cvf "${tmpFile}" --exclude=".DS_Store" "${@}" || return 1

  local size
  size=$(
    stat -f"%z" "${tmpFile}" 2>/dev/null  # macOS stat
    stat -c"%s" "${tmpFile}" 2>/dev/null  # GNU stat
  )

  local cmd=""
  if ((size < 52428800)) && hash zopfli 2>/dev/null; then
    cmd="zopfli"
  elif hash pigz 2>/dev/null; then
    cmd="pigz"
  else
    cmd="gzip"
  fi

  echo "Compressing .tar using \`${cmd}\`..."
  "${cmd}" -v "${tmpFile}" || return 1
  [ -f "${tmpFile}" ] && rm "${tmpFile}"
  echo "${tmpFile}.gz created successfully."
}

# Determine size of a file or total size of a directory
fs() {
  if du -b /dev/null >/dev/null 2>&1; then
    local arg=-sbh
  else
    local arg=-sh
  fi
  if [[ -n "$*" ]]; then
    du $arg -- "$@"
  else
    du $arg .[^.]* ./*
  fi
}

# Use Git's colored diff when available
if hash git &>/dev/null; then
  diff() {
    git diff --no-index --color-words "$@"
  }
fi

# Create a data URL from a file
dataurl() {
  local mimeType
  mimeType=$(file -b --mime-type "$1")
  if [[ $mimeType == text/* ]]; then
    mimeType="${mimeType};charset=utf-8"
  fi
  echo "data:${mimeType};base64,$(openssl base64 -in "$1" | tr -d '\n')"
}

# Compare original and gzipped file size
gz() {
  local origsize gzipsize ratio
  origsize=$(wc -c <"$1")
  gzipsize=$(gzip -c "$1" | wc -c)
  ratio=$(echo "$gzipsize * 100 / $origsize" | bc -l)
  printf "orig: %d bytes\n" "$origsize"
  printf "gzip: %d bytes (%2.2f%%)\n" "$gzipsize" "$ratio"
}

# Pretty-print JSON using jq (with bat highlighting if available)
json() {
  if [ -t 0 ]; then
    if command -v bat &>/dev/null; then
      jq '.' <<<"$*" | bat --language json --paging=never
    else
      jq '.' <<<"$*"
    fi
  else
    if command -v bat &>/dev/null; then
      jq '.' | bat --language json --paging=never
    else
      jq '.'
    fi
  fi
}

# Run dig and display the most useful info
digga() {
  dig +nocmd "$1" any +multiline +noall +answer
}

# UTF-8-encode a string of Unicode symbols
escape() {
  # shellcheck disable=SC2046
  printf "\\\x%s" $(printf "$@" | xxd -p -c1 -u)
  if [ -t 1 ]; then
    echo ""
  fi
}

# Decode \x{ABCD}-style Unicode escape sequences
unidecode() {
  perl -e "binmode(STDOUT, ':utf8'); print \"$*\""
  if [ -t 1 ]; then
    echo ""
  fi
}

# Get a character's Unicode code point
codepoint() {
  perl -e "use utf8; print sprintf('U+%04X', ord(\"$*\"))"
  if [ -t 1 ]; then
    echo ""
  fi
}

# Show all the names (CNs and SANs) listed in the SSL certificate for a given domain
getcertnames() {
  if [ -z "${1}" ]; then
    echo "ERROR: No domain specified."
    return 1
  fi

  local domain="${1}"
  echo "Testing ${domain}..."
  echo ""

  local tmp
  tmp=$(echo -e "GET / HTTP/1.0\nEOT" \
    | openssl s_client -connect "${domain}:443" -servername "${domain}" 2>&1)

  if [[ "${tmp}" == *"-----BEGIN CERTIFICATE-----"* ]]; then
    local certText
    certText=$(echo "${tmp}" \
      | openssl x509 -text -certopt "no_aux, no_header, no_issuer, no_pubkey, \
      no_serial, no_sigdump, no_signame, no_validity, no_version")
    echo "Common Name:"
    echo ""
    echo "${certText}" | grep "Subject:" | sed -e "s/^.*CN=//" | sed -e "s/\/emailAddress=.*//"
    echo ""
    echo "Subject Alternative Name(s):"
    echo ""
    echo "${certText}" | grep -A 1 "Subject Alternative Name:" \
      | sed -e "2s/DNS://g" -e "s/ //g" | tr "," "\n" | tail -n +2
    return 0
  else
    echo "ERROR: Certificate not found."
    return 1
  fi
}

# Open the current directory or given path in Vim
v() {
  if [ $# -eq 0 ]; then
    vim .
  else
    vim "$@"
  fi
}

# Open the current directory or given path
o() {
  if [ $# -eq 0 ]; then
    open .
  else
    open "$@"
  fi
}

# tree with hidden files, color, ignoring .git, directories first
tre() {
  tree -aC -I '.git|node_modules|bower_components' --dirsfirst "$@" | less -FRNX
}

# Docker cleanup: remove stopped containers and dangling images
dcleanup() {
  docker rm -v "$(docker ps --filter status=exited -q 2>/dev/null)" 2>/dev/null
  docker rmi "$(docker images --filter dangling=true -q 2>/dev/null)" 2>/dev/null
}

# Decode a Kubernetes secret's username and password
decode_k8s_secret() {
  local namespace=$1
  local secret_name=$2
  if [[ -z "$namespace" ]] || [[ -z "$secret_name" ]]; then
    echo "Usage: decode_k8s_secret <namespace> <secret_name>"
    return 1
  fi

  local base64_decode="base64 -d"
  if [[ "$(uname -s)" == "Darwin" ]]; then
    base64_decode="base64 -D"
  fi

  local user pass user_decoded pass_decoded
  user=$(kubectl get secret -n "${namespace}" "${secret_name}" -o yaml | grep username | cut -d ':' -f2 | tr -d ' ')
  pass=$(kubectl get secret -n "${namespace}" "${secret_name}" -o yaml | grep password | cut -d ':' -f2 | tr -d ' ')
  user_decoded=$(echo "${user}" | ${base64_decode})
  pass_decoded=$(echo "${pass}" | ${base64_decode})
  echo "User: ${user_decoded}"
  echo "Pass: ${pass_decoded}"
}

# Convert milliseconds timestamp to date
millis_to_date() {
  date -r $(($1 / 1000))
}

# Parse traceparent from base64-encoded string
parse_traceparent_base64() {
  echo "$1" | base64 -D | jq -r '.traceparent' | cut -d '-' -f 2
}

# Combine PDF files using Ghostscript
cpdf() {
  gs -q -dNOPAUSE -dBATCH -sDEVICE=pdfwrite -sOutputFile="$1" "${@:2}"
}

# GeoIP lookup
gip() {
  curl "https://json.geoiplookup.io/$1" 2>/dev/null
}

# URL-encode special characters per RFC 3986
urlencode() {
  local LC_ALL=C
  local c i n=${#1}
  for ((i = 0; i < n; i++)); do
    c="${1:i:1}"
    case "$c" in
      [-_.~A-Za-z0-9]) printf '%s' "$c" ;;
      *) printf '%%%02X' "'$c" ;;
    esac
  done
  echo
}

# Sum a column of numbers from stdin
function awksum {
  awk '{sum+=$1} END {print sum}'
}

# Delete local branches whose remote tracking branch is gone
git-cleanup-branches() {
  git branch -vv | grep 'origin/.*: gone]' | awk '{print $1}' | xargs git branch -D
}

# Git worktree helper: create new worktree with branch
gwt() {
  local name="$1"
  local type="${2:-feat}"
  local base="${3:-dev}"
  local dir
  dir="$(basename "$PWD")"
  local dest_dir="../${dir}__${name}"
  local branch="${type}/${name}"
  local existing
  existing=$(git branch -l "$branch")

  if [[ -z "$name" ]]; then
    echo "Usage: gwt <name> [type=feat] [base=dev]"
    return 1
  fi

  if [[ -n "$existing" ]]; then
    echo "Branch \"${branch}\" already exists."
    printf "Delete it and recreate? [y/N] "
    read -r confirm
    if [[ "${confirm}" =~ ^[Yy]$ ]]; then
      git branch -D "${branch}"
    else
      echo "Aborting."
      return 1
    fi
  fi

  git worktree add -b "${type}/${name}" "${dest_dir}" "$base"
  git worktree list
  cp -r .claude .env ./*-sa.json "${dest_dir}" 2>/dev/null || true
  cd "${dest_dir}" || return
}

# Git worktree helper: remove a worktree
gwr() {
  local name="$1"
  printf "Delete worktree %s? [y/N] " "$name"
  read -r confirm
  if [[ "${confirm}" =~ ^[Yy]$ ]]; then
    git worktree remove "$name"
  else
    echo "Aborting."
    return 1
  fi
}
